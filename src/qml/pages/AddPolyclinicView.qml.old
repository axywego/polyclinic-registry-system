import QtQuick
import QtQuick.Window
import QtQuick.Controls
import QtQuick.Layouts
import Polyclinic.Services 1.0

Rectangle {
    color: '#4b4b4b'

    ColumnLayout {
        anchors.top: parent.top
        anchors.left: parent.left

        anchors.margins: 16

        Layout.alignment: Qt.AlignTop | Qt.AlignLeft

        ColumnLayout {
            Layout.fillWidth: true

            // Name
            Text {
                text: "Введите название поликлиники:"
                color: "#fff"
            }

            TextField {
                id: nameField
                Layout.preferredHeight: 40
                Layout.minimumWidth: 300

                background: Rectangle {
                    anchors.fill: parent
                    color: '#fff'
                    border.color: "#e0e0e0"
                    radius: 6
                }
                color: "#000"
            }

            // Address
            Text {
                text: "Введите адрес поликлиники:"
                color: "#fff"
            }

            TextField {
                id: addressField
                Layout.preferredHeight: 40
                Layout.minimumWidth: 300

                background: Rectangle {
                    anchors.fill: parent
                    color: '#fff'
                    border.color: "#e0e0e0"
                    radius: 6
                }
                color: "#000"
            }

            // PhoneNumber
            Text {
                text: "Введите номер телефона поликлиники:"
                color: "#fff"
            }

            TextField {
                id: phoneNumberField
                Layout.preferredHeight: 40
                Layout.minimumWidth: 300

                background: Rectangle {
                    anchors.fill: parent
                    color: '#fff'
                    border.color: "#e0e0e0"
                    radius: 6
                }
                color: "#000"
            }

            Button {
                id: submitButton
                Layout.preferredHeight: 30
                Layout.minimumWidth: 120

                background: Rectangle {
                    anchors.fill: parent
                    color: submitButton.down ? '#cacaca' :
                            submitButton.hovered ? '#e6e6e6' : '#fff'
                    border.color: "#e0e0e0"
                    radius: 8

                    Text {
                        anchors.centerIn: parent
                        text: "Добавить"
                        color: "#000"
                        font.pixelSize: 16
                    }

                    Behavior on color {
                        ColorAnimation { duration: 200 }
                    }
                }
                onClicked: addPolyclinic()
            }
        }
    }

    function addPolyclinic() {
        if (!nameField.text || !addressField.text || !phoneNumberField.text) {
            return
        }

        var clinicData = {
            "name": nameField.text,
            "address": addressField.text,
            "phoneNumber": phoneNumberField.text
        }

        var success = PolyclinicService.add(clinicData)

        if (success) {
            nameField.text = ""
            addressField.text = ""
            phoneNumberField.text = ""
            
        }
        else {
            console.error("Ошибка при добавлении")
        }
    }
}